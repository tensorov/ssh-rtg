# reverse-ssh-gateway — client configuration
# Copy to config.env and fill in your values.

# VPS gateway details
GATEWAY_HOST="gateway.example.com"
GATEWAY_PORT=22
GATEWAY_USER="tunnel"

# SSH key path (must be deployed on the gateway)
SSH_KEY_PATH="$HOME/.ssh/id_reverse_tunnel"

# Tunnel definitions: comma-separated "local_port:remote_port:target_host:target_port"
# Example: forwards VPS port 8080 to localhost:80
# TUNNELS="8080:80:localhost:80"

# Monitoring
POLL_INTERVAL=30
