# reverse-ssh-gateway — client configuration
# ============================================
# Copy to /etc/reverse-ssh-gateway/config.env or pass via --config to install.sh.
# tunnel.sh sources this file at startup.
#
# Lines starting with # are ignored.  All values except GATEWAY_HOST and
# SSH_KEY_PATH are optional (defaults shown in comments).
#
# ===========================================================================
# REQUIRED
# ===========================================================================

# VPS jump host reachable from the NAT'd client.
# Format: "user@hostname" or "user@ip-address"
GATEWAY_HOST="tunnel@gateway.example.com"

# Absolute path to the SSH private key.
# The corresponding public key must be authorised on the jump host.
SSH_KEY_PATH="/home/tunnel/.ssh/id_ed25519"

# ===========================================================================
# PORT FORWARDING
# ===========================================================================
#
# Space-separated list of remote=local port pairs.
# Each pair creates an SSH -R flag:  -R REMOTE_PORT:LOCAL_HOST:LOCAL_PORT
# The jump host listens on REMOTE_PORT and forwards connections back
# through the tunnel to LOCAL_PORT on this machine.
#
# Examples:
#   2022=22   SSH into the NAT'd host
#   8080=8080 Web service behind NAT
#
PORTS="2022=22"

# ===========================================================================
# UDP → TCP BRIDGES (requires socat)
# ===========================================================================
#
# For UDP-native protocols (DNS, syslog, NTP, etc.).  Space-separated
# list of local=remote port pairs.  The tunnel script spawns a socat(1)
# process per pair that listens on UDP LOCAL_PORT and pipes the traffic
# over TCP through the SSH tunnel to REMOTE_PORT.
#
# A counterpart socat on the VPS side must convert TCP back to UDP.
#
# Examples:
#   5353=5353 DNS through tunnel
#   514=514   Syslog through tunnel
#
UDP_BRIDGES=""

# ===========================================================================
# BIND ADDRESS FOR FORWARDED REMOTE PORTS
# ===========================================================================
#
# Address the SSH server binds on the VPS for each forwarded remote port.
#   127.0.0.1 = localhost only on VPS (default, recommended)
#   0.0.0.0   = all interfaces (less secure — exposes ports to internet)
LOCAL_HOST="127.0.0.1"

# ===========================================================================
# SSH SETTINGS
# ===========================================================================
GATEWAY_PORT=22
SERVER_ALIVE_INTERVAL=30
SERVER_ALIVE_COUNT_MAX=3

# ===========================================================================
# FIREWALL (optional — UFW on the NAT host)
# ===========================================================================
#
# Space-separated list of local ports to open with `ufw allow`.
# Leave empty to skip firewall management.
UFW_OPEN=""

# ===========================================================================
# ADVANCED
# ===========================================================================
#
# Extra SSH -o options.  Example:
#   SSH_EXTRA_OPTS="-o ProxyJump=bastion.example.com -o IdentityFile=~/.ssh/other"
SSH_EXTRA_OPTS=""
